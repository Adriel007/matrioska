# Matrioska V3 — environment template
# Copy to .env (gitignored) and configure your provider.
# Precedence: CLI flag > env var > .env > dataclass default.

# ─── Provider ────────────────────────────────────────────────────────────────
# MATRIOSKA_PROVIDER=openai
# MATRIOSKA_BASE_URL=https://api.openai.com/v1
# MATRIOSKA_API_KEY=sk-...
# MATRIOSKA_MODEL=gpt-4o-mini

# ─── Multi-Model Architecture (§4.2) ─────────────────────────────────────────
# MATRIOSKA_ARCHITECT_MODEL=gpt-4o          # Strong reasoning for decomposition
# MATRIOSKA_GENERATOR_MODEL=gpt-4o-mini     # Balanced cost/quality
# MATRIOSKA_VALIDATOR_MODEL=gpt-4o-mini     # Cheap/fast for syntax checks
# MATRIOSKA_JUDGE_MODEL=gpt-4o              # Analytical precision for voting

# ─── OpenRouter (multi-provider gateway) ─────────────────────────────────────
# MATRIOSKA_PROVIDER=openai
# MATRIOSKA_BASE_URL=https://openrouter.ai/api/v1
# MATRIOSKA_API_KEY=sk-or-...
# MATRIOSKA_MODEL=anthropic/claude-sonnet-4
# MATRIOSKA_ARCHITECT_MODEL=anthropic/claude-opus-4

# ─── Anthropic native ────────────────────────────────────────────────────────
# MATRIOSKA_PROVIDER=anthropic
# MATRIOSKA_BASE_URL=https://api.anthropic.com
# MATRIOSKA_API_KEY=sk-ant-...
# MATRIOSKA_MODEL=claude-sonnet-4
# MATRIOSKA_ARCHITECT_MODEL=claude-opus-4

# ─── Ollama local ────────────────────────────────────────────────────────────
# MATRIOSKA_PROVIDER=openai
# MATRIOSKA_BASE_URL=http://localhost:11434/v1
# MATRIOSKA_API_KEY=ollama
# MATRIOSKA_MODEL=llama3.1:8b

# ─── Pipeline ────────────────────────────────────────────────────────────────
# MATRIOSKA_WORK_DIR=./matrioska_work
# MATRIOSKA_MAX_TOKENS=4096
# MATRIOSKA_MAX_REPAIRS=2
# MATRIOSKA_MAX_DEPTH=2
# MATRIOSKA_PARALLEL=true
# MATRIOSKA_PLAN_ONLY=false

# ─── Tree of Thoughts ────────────────────────────────────────────────────────
# MATRIOSKA_ARCHITECT_CANDIDATES=3
# MATRIOSKA_ARCHITECT_TEMPERATURE=0.7
# MATRIOSKA_ENABLE_TOT=true
# MATRIOSKA_ENABLE_REFLEXION=true
# MATRIOSKA_ENABLE_DEBATE=false

# ─── Sandbox ─────────────────────────────────────────────────────────────────
# MATRIOSKA_ENABLE_SANDBOX=false
# MATRIOSKA_SANDBOX_TIMEOUT=30
# MATRIOSKA_SANDBOX_IMAGE=python:3.11-slim

# ─── Memory ──────────────────────────────────────────────────────────────────
# MATRIOSKA_RETRIEVE_K=3
# MATRIOSKA_ENABLE_GRAPHRAG=false

# ─── Observability ───────────────────────────────────────────────────────────
# MATRIOSKA_LOG_LEVEL=INFO
# MATRIOSKA_ENABLE_OTEL=false
# MATRIOSKA_ENABLE_COST_TRACKING=true
# MATRIOSKA_DRY_RUN=false
